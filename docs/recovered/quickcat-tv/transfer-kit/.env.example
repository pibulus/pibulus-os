# Copy to .env on the future TV server. Do not use this directly on the Pi.

TZ=Australia/Melbourne

# Bind to localhost until nginx/cloudflared are intentionally configured.
TUNARR_BIND=127.0.0.1
TUNARR_HOST_PORT=8100
TVS_BIND=127.0.0.1
TVS_HOST_PORT=3099

# New server paths.
QCTV_TUNARR_DATA=./data/tunarr
QCTV_MEDIA_ROOT=/srv/media

# Tunarr tuning.
TUNARR_LOG_LEVEL=INFO
TUNARR_SERVER_TRUST_PROXY=true
TUNARR_DISABLE_SEARCH_SNAPSHOT_IN_BACKUP=true
TUNARR_SEARCH_MAX_MEMORY=1024Mb

# Public names to wire only after local playback is stable.
QCTV_PUBLIC_TV_HOST=tv.quickcat.club
QCTV_PUBLIC_STREAM_HOST=stream.quickcat.club
