# IMMICH STACK CONFIG
# Copy this to .env - install.sh will generate passwords automatically
#   cp .env.example .env

# Storage locations
UPLOAD_LOCATION=/media/pibulus/passport/immich
DB_DATA_LOCATION=/var/lib/immich/postgres

# Database credentials (auto-generated by install.sh)
DB_PASSWORD=CHANGE_ME_run_install_sh
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Version
IMMICH_VERSION=release
