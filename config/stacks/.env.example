# IMMICH STACK CONFIG
# Copy this to .env - install.sh will generate passwords automatically
#   cp .env.example .env

# Storage locations
UPLOAD_LOCATION=/media/pibulus/passport/immich
DB_DATA_LOCATION=/var/lib/immich/postgres

# Database credentials (auto-generated by install.sh)
DB_PASSWORD=CHANGE_ME_run_install_sh
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Version
IMMICH_VERSION=release

# Soulseek / slskd
SLSKD_SLSK_PASSWORD=CHANGE_ME

# Optional VPN passthrough
PUREVPN_USER=
PUREVPN_PASSWORD=

# RomM
DB_PASSWD=CHANGE_ME
ROMM_AUTH_SECRET_KEY=CHANGE_ME
ROMM_AUTH_PASSWORD=CHANGE_ME
IGDB_CLIENT_ID=CHANGE_ME
IGDB_CLIENT_SECRET=CHANGE_ME
MARIADB_ROOT_PASSWORD=CHANGE_ME
MARIADB_PASSWORD=CHANGE_ME
