[Unit]
Description=Hexbloop Fresh Site
After=network.target

[Service]
Type=simple
User=pibulus
WorkingDirectory=/home/pibulus/apps/hexbloop-site
ExecStart=/home/pibulus/.deno/bin/deno run -A main.ts
Environment=PORT=9010
Environment=HOST=0.0.0.0
Environment=SITE_URL=https://hexbloop.app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
