[Unit]
Description=Spellbreak Fresh Site
After=network.target

[Service]
Type=simple
User=pibulus
WorkingDirectory=/home/pibulus/apps/spellbreak-site
ExecStart=/home/pibulus/.deno/bin/deno run -A main.ts
Environment=PORT=9011
Environment=HOST=0.0.0.0
Environment=SITE_URL=https://spellbreak.app
Environment=SQUARE_ENVIRONMENT=production
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
