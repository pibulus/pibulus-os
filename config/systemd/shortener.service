[Unit]
Description=Pibulus URL Shortener
After=network.target

[Service]
Type=simple
User=pibulus
WorkingDirectory=/home/pibulus/pibulus-os
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /home/pibulus/pibulus-os/scripts/shortener.py
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
MemoryAccounting=yes
MemoryMax=128M

[Install]
WantedBy=multi-user.target
