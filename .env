# 🗝️ PIBULUS OS GLOBAL CONFIG
# Change these and the whole deck follows.

# Where the big iron lives
PASSPORT_ROOT="/media/pibulus/passport"
WEB_ROOT="/media/pibulus/passport/www/html"

# The human in the machine
SYSTEM_USER="pibulus"

# Infrastructure
CF_CONFIG="/etc/cloudflared/config.yml"
TUNNEL_NAME="pibulus-tunnel"
